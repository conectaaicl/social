generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(OWNER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  tenantId      String?

  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Tenant ─────────────────────────────────────────────

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  plan        PlanType @default(BASIC)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  socialAccounts  SocialAccount[]
  brandVoice      BrandVoice?
  posts           Post[]
  mediaLibrary    MediaItem[]
  calendar        CalendarConfig?

  @@map("tenants")
}

// ─── Social Accounts ────────────────────────────────────

model SocialAccount {
  id                String        @id @default(cuid())
  platform          Platform
  accountId         String
  accountName       String
  accessToken       String
  tokenExpiresAt    DateTime?
  pageId            String?       // Facebook Page ID
  active            Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  tenantId          String

  posts             Post[]

  @@unique([tenantId, platform, accountId])
  @@map("social_accounts")
}

// ─── Brand Voice ────────────────────────────────────────

model BrandVoice {
  id            String   @id @default(cuid())
  industry      String
  description   String
  tone          String   // cercano, elegante, técnico, divertido...
  keywords      String[] // palabras clave del negocio
  products      String[] // productos/servicios principales
  targetAudience String
  language      String   @default("es-CL")
  customPrompt  String?  // prompt adicional personalizado
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  tenantId      String   @unique

  @@map("brand_voices")
}

// ─── Calendar Config ────────────────────────────────────

model CalendarConfig {
  id              String   @id @default(cuid())
  postsPerDay     Int      @default(3)
  scheduleSlots   Json     // [{time: "09:00", type: "feed"}, {time: "13:00", type: "story"}, ...]
  contentMix      Json     // {producto: 30, tip: 25, proyecto: 25, promo: 20}
  autoPublish     Boolean  @default(true)
  timezone        String   @default("America/Santiago")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  tenantId        String   @unique

  @@map("calendar_configs")
}

// ─── Posts ──────────────────────────────────────────────

model Post {
  id              String      @id @default(cuid())
  type            PostType
  contentType     ContentType
  platform        Platform[]
  status          PostStatus  @default(PENDING)

  caption         String
  hashtags        String
  imagePrompt     String?
  videoPrompt     String?

  mediaUrls       String[]
  thumbnailUrl    String?

  scheduledAt     DateTime
  publishedAt     DateTime?
  failedAt        DateTime?
  failReason      String?

  metaPostId      String?     // ID retornado por Meta al publicar
  reach           Int?
  likes           Int?
  comments        Int?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  tenantId        String

  socialAccount   SocialAccount? @relation(fields: [socialAccountId], references: [id])
  socialAccountId String?

  @@map("posts")
}

// ─── Media Library ──────────────────────────────────────

model MediaItem {
  id          String      @id @default(cuid())
  url         String
  type        MediaType
  source      MediaSource
  prompt      String?
  width       Int?
  height      Int?
  duration    Int?        // segundos, para videos
  tags        String[]
  createdAt   DateTime    @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  tenantId    String

  @@map("media_items")
}

// ─── Enums ──────────────────────────────────────────────

enum UserRole {
  SUPERADMIN
  OWNER
  EDITOR
}

enum PlanType {
  BASIC
  PRO
  AGENCY
}

enum Platform {
  INSTAGRAM
  FACEBOOK
}

enum PostType {
  FEED
  STORY
  CAROUSEL
  REEL
}

enum ContentType {
  PRODUCTO
  PROYECTO
  TIP
  PROMO
}

enum PostStatus {
  PENDING
  GENERATING
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaSource {
  AI_GENERATED
  UPLOADED
  STOCK
}
