# App
NEXT_PUBLIC_APP_URL=https://social.conectaai.cl
NEXTAUTH_URL=https://social.conectaai.cl
NEXTAUTH_SECRET=REEMPLAZAR_CON_OPENSSL_RAND_BASE64_32

# Database
DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/social_db

# Anthropic
ANTHROPIC_API_KEY=REEMPLAZAR_CON_TU_API_KEY

# fal.ai (generación de imágenes)
FAL_KEY=REEMPLAZAR_CON_TU_FAL_KEY

# Replicate (fallback imágenes / video)
REPLICATE_API_TOKEN=REEMPLAZAR_CON_TU_TOKEN

# Meta / Instagram
META_APP_ID=REEMPLAZAR_CON_TU_APP_ID
META_APP_SECRET=REEMPLAZAR_CON_TU_APP_SECRET

# mail.conectaai.cl
MAILSAAS_API_KEY=REEMPLAZAR_CON_TU_API_KEY
MAILSAAS_API_URL=https://mail.conectaai.cl/api
MAIL_FROM=noreply@social.conectaai.cl

# Cron secret — n8n lo usa como Authorization: Bearer {CRON_SECRET}
# Genera con: openssl rand -base64 32
CRON_SECRET=REEMPLAZAR_CON_OPENSSL_RAND_BASE64_32

# Evolution API / WhatsApp (OmniFlow)
EVOLUTION_API_URL=REEMPLAZAR_CON_TU_URL
EVOLUTION_API_KEY=REEMPLAZAR_CON_TU_KEY
WHATSAPP_INSTANCE=REEMPLAZAR_CON_TU_INSTANCIA
